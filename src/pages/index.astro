                        <video src="https://servicebigboys.my.canva.site/_assets/video/4dbf2842ad15b88fe52cacb7f3de9fd3.mp4" loop muted playsinline preload="metadata" class="hover-play"></video>
                        <div class="play-indicator"><i data-lucide="play" class="text-kintsugi-gold w-8 h-8 fill-current"></i></div>
