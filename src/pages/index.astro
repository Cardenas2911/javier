                        </div>
                        <span class="text-[10px] font-bold tracking-widest text-gray-400 uppercase">Diseño UX/UI</span>
                    </div>

                    <div class="flex flex-col items-center opacity-60 hover:opacity-100 transition-all hover:scale-110 cursor-pointer">
                        <div class="w-14 h-14 rounded-xl bg-black flex items-center justify-center mb-3 border border-[#4285F4] shadow-[0_0_15px_rgba(66,133,244,0.2)]">
                            <i data-lucide="megaphone" class="w-7 h-7 text-[#4285F4]"></i>
                        </div>
                        <span class="text-[10px] font-bold tracking-widest text-gray-400 uppercase">Ads</span>
                    </div>

                    <div class="flex flex-col items-center opacity-60 hover:opacity-100 transition-all hover:scale-110 cursor-pointer">
                        <div class="w-14 h-14 rounded-xl bg-black flex items-center justify-center mb-3 border border-gray-600 shadow-[0_0_15px_rgba(255,255,255,0.1)]">
                            <svg viewBox="0 0 24 24" fill="none" class="w-8 h-8 text-white" stroke="currentColor" stroke-width="1.5">
                                <path d="M12 4L4 8L12 12L20 8L12 4Z" fill="white"/>
                                <path d="M4 12L12 16L20 12" stroke="white" stroke-width="2"/>
                                <path d="M4 16L12 20L20 16" stroke="white" stroke-width="2"/>
                            </svg>
                        </div>
