---
const pillars = [
  { text: "EDICIÓN CINEMÁTICA", emoji: "🎬" },
  { text: "REELS & TIKTOKS VIRALES", emoji: "🔥" },
  { text: "GANCHOS NEURO-VISUALES", emoji: "🧠" },
  { text: "DISEÑO SONORO INMERSIVO", emoji: "🔊" },
  { text: "CORRECCIÓN DE COLOR CINEMÁTICA", emoji: "🎨" },
  { text: "METODOLOGÍA MAES", emoji: "⚡" },
  { text: "ESTRATEGIA DE RETENCIÓN", emoji: "📈" },
  { text: "ANUNCIOS DE ALTO IMPACTO", emoji: "🚀" },
  { text: "DOCUMENTALES DE MARCA", emoji: "🎥" },
];
---

<div class="relative overflow-x-hidden px-4 py-6 bg-black/60 border-y border-gray-900">
  <div class="animate-scroll hover:animate-paused flex w-max gap-16 md:gap-24 items-center">
    {
      pillars.concat(pillars, pillars).map((pillar) => (
        <div class="group flex items-center gap-3 transition-all duration-300">
          <span class="text-2xl filter drop-shadow-[0_0_8px_rgba(239,68,68,0.5)]">
            {pillar.emoji}
          </span>
          <span class="text-base md:text-lg font-black tracking-wider text-white hover:text-[#ef4444] transition-colors select-none font-mono">
            {pillar.text}
          </span>
          <span class="text-[#ef4444] font-bold text-xl ml-4">•</span>
        </div>
      ))
    }
  </div>
</div>

<style is:global>
  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .animate-scroll {
    animation: scroll 60s linear infinite;
  }

  @media (min-width: 768px) {
    .animate-scroll {
      animation-duration: 80s;
    }
  }
</style>
