---
// PlantillaBase.astro - Plantilla principal de la aplicación en español bajo Metodología MAES
import '../styles/global.css';
import { inicializarSentry } from '../lib/telemetria.ts';

interface Props {
  titulo: string;
  descripcion?: string;
}

const { titulo, descripcion = "Proyecto de alto rendimiento inicializado con Metodología MAES, Astro, React, Tailwind CSS y Lordicon" } = Astro.props;

// Inicialización de Sentry en el Servidor
inicializarSentry();
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=0.9" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Metaetiquetas SEO -->
    <title>{titulo} | Metodología MAES</title>
    <meta name="description" content={descripcion} />
    <meta name="robots" content="index, follow" />
    
    <!-- Tipografías Premium desde Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Estilos en línea para variables tipográficas globales y fondo de alto rendimiento -->
    <style>
      :root {
        --fuente-base: 'Plus Jakarta Sans', sans-serif;
        --fuente-titulo: 'Space Grotesk', sans-serif;
      }
      body {
        font-family: var(--fuente-base);
        background-color: #030712; /* Fondo ultra oscuro premium */
        color: #f3f4f6;
      }
      .tipografia-titulo {
        font-family: var(--fuente-titulo);
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden selection:bg-indigo-500/30 selection:text-indigo-200" data-sujeto="AplicacionMAES" data-predicado="instanciaDe" data-objeto="ProyectoAltoRendimiento">
    <!-- Fondo decorativo con gradientes orbitales -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute -top-[40%] -left-[20%] w-[80vw] h-[80vw] rounded-full bg-indigo-900/15 blur-[120px]"></div>
      <div class="absolute -bottom-[20%] -right-[10%] w-[60vw] h-[60vw] rounded-full bg-purple-900/10 blur-[100px]"></div>
      <div class="absolute top-[30%] left-[50%] -translate-x-1/2 w-[50vw] h-[50vw] rounded-full bg-cyan-900/10 blur-[130px]"></div>
    </div>

    <!-- Navegación Premium -->
    <header class="sticky top-0 z-50 backdrop-blur-md bg-gray-950/70 border-b border-gray-800/80 transition-all duration-300" data-sujeto="CabeceraNavegacion" data-predicado="contieneMenu" data-objeto="NavegacionEstructural">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="relative flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-cyan-400 p-[1px] shadow-lg shadow-indigo-500/20">
            <div class="w-full h-full rounded-[11px] bg-gray-950 flex items-center justify-center font-bold text-transparent bg-clip-text bg-gradient-to-r from-indigo-300 to-cyan-300 tipografia-titulo">
              M
            </div>
          </div>
          <div>
            <span class="text-xl font-bold tracking-tight text-white tipografia-titulo">Metodología <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-cyan-300">MAES</span></span>
          </div>
        </div>

        <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-400" data-sujeto="EnlacesNavegacion" data-predicado="redirigenA" data-objeto="SeccionesPagina">
          <a href="#inicio" class="hover:text-white transition-colors duration-200">Inicio</a>
          <a href="#pilares" class="hover:text-white transition-colors duration-200">Pilares MAES</a>
          <a href="#tecnologias" class="hover:text-white transition-colors duration-200">Tecnologías</a>
          <a href="#demostracion" class="hover:text-white transition-colors duration-200">Demostración React</a>
        </nav>

        <div class="flex items-center gap-4">
          <a href="#demostracion" class="relative group px-5 py-2.5 rounded-xl text-xs font-semibold tracking-wider uppercase text-white overflow-hidden transition-all duration-300">
            <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-indigo-600 to-cyan-500 transition-all duration-300 group-hover:scale-105"></span>
            <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-indigo-500 to-cyan-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
            <span class="relative z-10 flex items-center gap-2">
              Ver Demo
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </span>
          </a>
        </div>
      </div>
    </header>

    <!-- Contenido Principal -->
    <main class="flex-grow" data-sujeto="ContenidoPrincipal" data-predicado="renderizaSecciones" data-objeto="ComponentesRendimiento">
      <slot />
    </main>

    <!-- Pie de Página -->
    <footer class="border-t border-gray-900 bg-gray-980 py-12 text-center text-sm text-gray-500" data-sujeto="PiePagina" data-predicado="contieneInformacion" data-objeto="DerechosAutor">
      <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
        <p>© 2026 Metodología MAES. Todos los derechos reservados.</p>
        <p class="flex items-center gap-2">
          Creado con 
          <span class="text-rose-500 animate-pulse">❤️</span> 
          para el alto rendimiento y la excelencia en el desarrollo web.
        </p>
      </div>
    </footer>

    <!-- Script de Cliente para Observabilidad de Sentry -->
    <script>
      import { inicializarSentry } from '../lib/telemetria.ts';
      inicializarSentry();
    </script>
  </body>
</html>
