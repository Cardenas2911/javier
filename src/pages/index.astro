                        <div class="play-indicator"><i data-lucide="play" class="text-kintsugi-gold w-8 h-8 fill-current"></i></div>
                    </div>
                    <div class="video-container cursor-pointer hidden lg:block mt-0 md:mt-12">
                        <video src="https://servicebigboys.my.canva.site/_assets/video/e2077d16e3fa80baf570a61e3524019c.mp4" loop muted playsinline preload="metadata" class="hover-play"></video>
                        <div class="play-indicator"><i data-lucide="play" class="text-kintsugi-gold w-8 h-8 fill-current"></i></div>
