            </div>
        </div>
    </section>

    <!-- SECCIÓN DE PERFIL MEJORADA -->
    <section id="perfil" class="py-32 bg-kintsugi-dark border-y border-white/5 relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiLz48L3N2Zz4=')] opacity-50"></div>
        
        <div class="max-w-screen-xl mx-auto px-6 relative z-10">
            
            <!-- CONTENEDOR SUPERIOR: 2 Columnas (Texto y Tarjetas) -->
            <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
                
                <!-- Columna Izquierda: Texto -->
                <div class="w-full lg:w-1/2">
                    <div class="w-24 h-24 md:w-32 md:h-32 rounded-full overflow-hidden mb-8 border-2 border-kintsugi-gold shadow-[0_0_20px_rgba(255,215,0,0.2)]">
                        <img src="image_b4c894.jpg" alt="Javier Cuevas" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500">
                    </div>
                    
                    <h2 class="text-sm font-bold uppercase tracking-[0.3em] text-kintsugi-gold mb-4">Sobre Mí</h2>
                    <h3 class="text-4xl md:text-5xl font-display font-black mb-8 leading-tight">Narrativas visuales con <span class="text-gradient-gold">impacto real.</span></h3>
                    
                    <div class="text-gray-400 text-lg font-light space-y-6">
                        <p>
                            Soy <strong>Realizador Audiovisual y Editor de Video</strong>. Mi objetivo es simple: transformar material crudo en historias que retienen la atención y conectan con la audiencia.
                        </p>
                        <p>
                            Domino desde la profundidad de un <strong>documental corporativo</strong> hasta el ritmo vertiginoso de los <strong>Videos Cortos (Reels/TikToks)</strong>, integrando siempre diseño sonoro y corrección de color para garantizar resultados estéticos y funcionales.
                        </p>
                    </div>
                </div>
                
                <!-- Columna Derecha: Tarjetas Reorganizadas -->
                <div class="w-full lg:w-1/2">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 h-full content-start">
                        <div class="bg-kintsugi-gray p-8 rounded-2xl border border-white/5 hover:border-kintsugi-gold/30 transition-all hover:-translate-y-1">
                            <i data-lucide="layers" class="text-white w-8 h-8 mb-4"></i>
                            <h4 class="text-white font-bold mb-2 text-lg">Multi-Formato</h4>
                            <p class="text-sm text-gray-500">Experticia en documentales, corporativos y contenido vertical de alto rendimiento.</p>
                        </div>
                        
                        <div class="bg-kintsugi-gray p-8 rounded-2xl border border-white/5 hover:border-kintsugi-gold/30 transition-all hover:-translate-y-1">
                            <i data-lucide="layout" class="text-white w-8 h-8 mb-4"></i>
                            <h4 class="text-white font-bold mb-2 text-lg">Diseño UX/UI</h4>
                            <p class="text-sm text-gray-500">Creación de interfaces intuitivas y estéticas orientadas a la conversión y la mejor experiencia de usuario.</p>
                        </div>
                        
                        <div class="bg-kintsugi-gray p-8 rounded-2xl border border-white/5 hover:border-kintsugi-gold/30 transition-all hover:-translate-y-1">
                            <i data-lucide="megaphone" class="text-white w-8 h-8 mb-4"></i>
                            <h4 class="text-white font-bold mb-2 text-lg">Tráfico & Ads</h4>
                            <p class="text-sm text-gray-500">Administración estratégica de anuncios para escalar captación y ventas.</p>
                        </div>
                        
                        <div class="bg-kintsugi-gray p-8 rounded-2xl border border-white/5 hover:border-kintsugi-gold/30 transition-all hover:-translate-y-1">
