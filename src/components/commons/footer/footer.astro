---
import SocialIcons from "../socialIcons/socialIcons.jsx";
const baseUrl = import.meta.env.BASE_URL;
---

<footer class="bg-gray-950 text-white border-t border-white/5">
  <div
    class="container mx-auto flex flex-col items-center justify-between px-6 py-12 lg:flex-row lg:px-20"
  >
    <!-- Logo -->
    <a href={baseUrl} class="flex items-center">
      <h3
        class="text-[#ef4444] text-3xl font-black tracking-widest font-display drop-shadow-[1.5px_1.5px_0_#8c0303] uppercase"
      >
        KINTSUGI
      </h3>
    </a>

    <!-- Navigation Links -->
    <nav class="mb-4 lg:mb-0">
      <ul
        class="flex flex-col items-center space-y-2 text-gray-400 lg:flex-row lg:items-start lg:space-y-0 lg:space-x-6"
      >
        <li>
          <a href={baseUrl} class="hover:text-[#ef4444] font-semibold transition-colors">Inicio</a>
        </li>
        <li>
          <a href={`${baseUrl}servicios`} class="hover:text-[#ef4444] font-semibold transition-colors">Servicios</a>
        </li>
        <li>
          <a href={`${baseUrl}proyectos`} class="hover:text-[#ef4444] font-semibold transition-colors">Proyectos</a>
        </li>
        <li>
          <a href={`${baseUrl}about`} class="hover:text-[#ef4444] font-semibold transition-colors">Sobre Mí</a>
        </li>
        <li>
          <a href={`${baseUrl}contact`} class="hover:text-[#ef4444] font-semibold transition-colors">Contacto</a>
        </li>
      </ul>
    </nav>

    <!-- Social Media Links -->
    <div class="flex space-x-4">
      <SocialIcons client:visible />
    </div>
  </div>

  <!-- Copyright -->
  <div
    class="w-full border-t border-white/5 py-10 text-center text-xs text-gray-500 uppercase tracking-widest font-bold"
  >
    Javier Cuevas © 2026 • Creativos Kintsugi • Diseñado en Bogotá
  </div>
</footer>
