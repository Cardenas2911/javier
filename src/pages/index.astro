                    </div>
                </div>
            </div>

            <!-- CONTENEDOR INFERIOR: Apartado de Desarrollo Web y Ads -->
            <div class="w-full mt-24 bg-gradient-to-r from-kintsugi-gold/10 to-transparent border border-kintsugi-gold/30 rounded-[2rem] p-8 md:p-12 relative overflow-hidden">
                <!-- Glow decorativo de fondo -->
                <div class="absolute -right-20 -top-20 w-64 h-64 bg-kintsugi-gold/20 rounded-full blur-[80px]"></div>
                
                <div class="relative z-10 w-full">
                    <h4 class="text-kintsugi-gold font-bold uppercase tracking-[0.2em] text-xs mb-3 flex items-center gap-2">
                        <i data-lucide="rocket" class="w-4 h-4"></i> Escalabilidad Digital
                    </h4>
                    <h3 class="text-3xl md:text-4xl font-display font-black text-white mb-4 leading-tight">Desarrollo Web & <br>Ventas en Automático</h3>
                    <p class="text-gray-400 text-lg font-light leading-relaxed max-w-3xl">
                        No solo edito contenido visual para que luzca increíble; construyo el ecosistema completo para que tu negocio crezca. Desarrollo <strong>Embudos de Venta (Funnels) con excelente Diseño UX/UI</strong>, optimizados estratégicamente con la <strong>administración de anuncios (Ads)</strong> para captar clientes y escalar tus ingresos en automático.
                    </p>
                </div>
            </div>

        </div>
    </section>

    <!-- Sección Contacto -->
    <section id="contacto" class="py-32 bg-kintsugi-dark relative">
        <div class="max-w-4xl mx-auto px-6 relative z-10">
            <div class="text-center mb-16">
                <h2 class="text-5xl font-display font-black mb-6">Iniciemos el <span class="text-kintsugi-gold italic">Corte.</span></h2>
                <p class="text-gray-400 text-xl font-light">Cuéntame sobre tu marca, tu volumen de contenido o la visión de tu próximo gran lanzamiento.</p>
            </div>
            
            <div class="bg-kintsugi-gray p-10 md:p-16 rounded-[2rem] border border-white/5 relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-kintsugi-gold/10 rounded-bl-full"></div>

                <form id="contactForm" class="space-y-8 relative z-10">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-3">Nombre / Agencia</label>
                            <input type="text" id="formName" required class="w-full bg-transparent border-b-2 border-white/10 px-0 py-3 text-white text-lg focus:outline-none focus:border-kintsugi-gold transition-colors placeholder-gray-700" placeholder="Ej. Juan Pérez">
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-3">WhatsApp Directo</label>
                            <input type="tel" id="formPhone" required class="w-full bg-transparent border-b-2 border-white/10 px-0 py-3 text-white text-lg focus:outline-none focus:border-kintsugi-gold transition-colors placeholder-gray-700" placeholder="+57 300 000 0000">
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-3">Tus Redes / Proyecto Actual</label>
                        <input type="text" id="formProject" class="w-full bg-transparent border-b-2 border-white/10 px-0 py-3 text-white text-lg focus:outline-none focus:border-kintsugi-gold transition-colors placeholder-gray-700" placeholder="Ej. @tu_cuenta o Link de YouTube">
                    </div>

                    <div>
                        <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-3">¿Qué buscas lograr?</label>
                        <select id="formGoal" class="w-full bg-transparent border-b-2 border-white/10 px-0 py-3 text-white text-lg focus:outline-none focus:border-kintsugi-gold transition-colors appearance-none cursor-pointer">
                            <option class="bg-kintsugi-dark text-white">Quiero delegar mi edición recurrente (Videos Cortos)</option>
                            <option class="bg-kintsugi-dark text-white">Tengo un lanzamiento o proyecto especial</option>
                            <option class="bg-kintsugi-dark text-white">Edición de formato largo (YouTube)</option>
                            <option class="bg-kintsugi-dark text-white">Busco colaboración comercial B2B</option>
                        </select>
                    </div>

                    <div class="pt-8">
                        <button type="submit" class="w-full bg-white text-kintsugi-dark font-black uppercase tracking-widest py-6 rounded-xl hover:bg-kintsugi-gold transition-all duration-300 text-lg flex justify-center items-center gap-3 group">
                            Enviar Propuesta 
                            <i data-lucide="arrow-up-right" class="w-6 h-6 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <!-- Modal Premium -->
    <div id="successModal" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/90 backdrop-blur-md hidden opacity-0 transition-opacity duration-300">
        <div class="bg-kintsugi-gray border border-white/10 p-12 rounded-3xl max-w-lg w-full text-center relative mx-4 transform scale-95 transition-transform duration-300 shadow-2xl">
            <div class="w-20 h-20 bg-kintsugi-gold rounded-full flex items-center justify-center mx-auto mb-8 shadow-[0_0_30px_rgba(255,215,0,0.3)]">
                <i data-lucide="check" class="text-kintsugi-dark w-10 h-10 stroke-[3px]"></i>
            </div>
            <h3 class="text-3xl font-display font-black text-white mb-4">Mensaje Recibido</h3>
            <p class="text-gray-400 mb-10 text-lg font-light">He recibido tus datos. Revisaré tu perfil y me pondré en contacto vía WhatsApp para organizar nuestra colaboración.</p>
            <button id="closeModalBtn" class="bg-white text-kintsugi-dark font-bold uppercase tracking-widest px-8 py-4 rounded-xl hover:bg-kintsugi-gold transition-colors w-full">
                Cerrar
            </button>
        </div>
    </div>

    

    <!-- Scripts -->
    <script>
        lucide.createIcons();

        const videos = document.querySelectorAll('.hover-play');
        
        videos.forEach(video => {
            video.pause();
            
            video.parentElement.addEventListener('mouseenter', () => {
                video.play().catch(e => console.log("Autoplay paused", e));
            });
            
            video.parentElement.addEventListener('mouseleave', () => {
                video.pause();
            });

            video.parentElement.addEventListener('touchstart', (e) => {
                if(video.paused) {
                    videos.forEach(v => { if(v !== video) v.pause(); });
                    video.play();
                } else {
                    video.pause();
                }
            }, {passive: true});
        });

        const form = document.getElementById('contactForm');
        const modal = document.getElementById('successModal');
        const closeBtn = document.getElementById('closeModalBtn');

        form.addEventListener('submit', function(e) {
            e.preventDefault();
            
            // 1. Recopilar los datos de los inputs
            const name = document.getElementById('formName').value;
            const phone = document.getElementById('formPhone').value;
            const project = document.getElementById('formProject').value || 'No especificado';
            const goal = document.getElementById('formGoal').value;
            
            // 2. Formatear el mensaje usando codificación de URL para los saltos de línea (%0A) y espacios
            const message = `¡Hola Javier! Vengo de tu portafolio y me gustaría proponerte una colaboración.%0A%0A*Mis Datos:*%0A👤 *Nombre/Agencia:* ${name}%0A📱 *WhatsApp:* ${phone}%0A🔗 *Proyecto/Redes:* ${project}%0A🎯 *Objetivo:* ${goal}`;
            
            // 3. Crear el link de WhatsApp con tu número
            const whatsappNumber = '573212264782';
            const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${message}`;
            
            // 4. Redirigir a WhatsApp
            window.open(whatsappUrl, '_blank');
            
            // 5. Mostrar la ventana de éxito de todas formas en la página base y limpiar
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.firstElementChild.classList.remove('scale-95');
                modal.firstElementChild.classList.add('scale-100');
            }, 10);
            this.reset();
        });

        closeBtn.addEventListener('click', function() {
            modal.classList.add('opacity-0');
            modal.firstElementChild.classList.remove('scale-100');
            modal.firstElementChild.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        });
    </script>

</PlantillaBase>
