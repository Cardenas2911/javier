---
import PlantillaBase from "../layouts/PlantillaBase.astro";
---

<PlantillaBase titulo="Portafolio | Javier Cuevas | Edición de Video" descripcion="Portafolio de Javier Cuevas. Dirección, edición de video, documentales, corporativos y contenido de alta retención.">
  <style is:global>
    
        body {
            background-color: #050505;
            color: #f3f4f6;
            scroll-behavior: smooth;
            overflow-x: hidden;
        }

        /* Tipografía Gigante Cinematográfica */
        .text-huge {
            font-size: clamp(3rem, 7vw, 6.5rem);
            line-height: 1.1;
            letter-spacing: -0.02em;
        }

        /* Gradiente dorado elegante */
        .text-gradient-gold {
            background: linear-gradient(135deg, #FFD700 0%, #ff8c00 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Efecto de foco en el portafolio */
        .portfolio-grid:hover .video-container:not(:hover),
        .portfolio-grid:hover .video-horizontal:not(:hover) {
            opacity: 0.3;
            filter: grayscale(80%);
        }

        /* Contenedor Vertical */
        .video-container {
            position: relative;
            width: 100%;
            padding-top: 177.77%; /* Ratio 9:16 vertical */
            background-color: #111111;
            border-radius: 0.75rem;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(255,255,255,0.05);
        }
        
        .video-container:hover {
            transform: scale(1.02);
            border-color: rgba(255, 215, 0, 0.5);
            box-shadow: 0 20px 40px -10px rgba(255, 215, 0, 0.15);
            z-index: 10;
        }

        .video-container video {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.7;
            transition: opacity 0.3s ease;
        }
        
        .video-container:hover video {
            opacity: 1;
        }

        /* Contenedor Horizontal */
        .video-horizontal {
            position: relative;
            width: 100%;
            padding-top: 56.25%; /* Ratio 16:9 */
            background-color: #111111;
            border-radius: 0.75rem;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(255,255,255,0.05);
        }

        .video-horizontal:hover {
            transform: scale(1.02);
            border-color: rgba(255, 215, 0, 0.5);
            box-shadow: 0 20px 40px -10px rgba(255, 215, 0, 0.15);
            z-index: 10;
        }

        .video-horizontal video {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.7;
            transition: opacity 0.3s ease;
        }

        .video-horizontal:hover video {
            opacity: 1;
        }

        /* Indicador de Play General */
        .play-indicator {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.8);
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            border-radius: 50%;
            padding: 1.5rem;
            opacity: 1;
            transition: all 0.3s ease;
            pointer-events: none;
            border: 1px solid rgba(255,215,0,0.3);
        }

        .video-container:hover .play-indicator,
        .video-horizontal:hover .play-indicator {
            opacity: 0;
            transform: translate(-50%, -50%) scale(1.2);
        }

        /* Líneas de escáner creativas de fondo */
        .scanlines {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,0) 50%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0.1));
            background-size: 100% 4px;
            z-index: 999;
            pointer-events: none;
            opacity: 0.15;
        }
    
  </style>

  <!-- Lucide Script -->
  <script is:inline src="https://unpkg.com/lucide@latest"></script>
  
  

    <div class="scanlines"></div>

    

    <!-- Hero Section con Background Video -->
    <section class="relative min-h-screen flex items-center pt-24 overflow-hidden">
        
        <!-- Video de Fondo (Neuromarketing) -->
        <div class="absolute inset-0 z-0">
            <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-40 pointer-events-none">
                <source src="https://servicebigboys.my.canva.site/_assets/video/1cfc39fd680b1e5bd96187965385a208.mp4" type="video/mp4">
            </video>
            <!-- Overlay degradado para que el texto sea 100% legible -->
            <div class="absolute inset-0 bg-gradient-to-b from-kintsugi-dark/70 via-kintsugi-dark/60 to-kintsugi-dark"></div>
        </div>

        <!-- Glows de fondo -->
        <div class="absolute top-1/4 -left-1/4 w-96 h-96 bg-kintsugi-gold/10 rounded-full blur-[120px] z-0"></div>
        
        <div class="w-full max-w-screen-2xl mx-auto px-6 relative z-10">
            <div class="max-w-5xl">
                <p class="text-kintsugi-gold font-bold tracking-[0.3em] uppercase text-sm mb-6 flex items-center gap-4">
                    <span class="w-12 h-[1px] bg-kintsugi-gold"></span> Realizador Audiovisual
                </p>
                
                <h1 class="font-display font-black text-huge text-white mb-2 uppercase drop-shadow-2xl">
                    Portafolio <br>
                    <span class="text-gradient-gold">Javier Cuevas</span>
                </h1>
                <h2 class="text-3xl md:text-5xl font-display font-light text-gray-200 tracking-[0.2em] uppercase mb-10 drop-shadow-lg">
                    Edición de Video
                </h2>
                
                <p class="text-xl md:text-2xl text-gray-300 font-light max-w-3xl leading-relaxed mb-8 drop-shadow-md">
                    Con más de 3 años de experiencia, transformo metraje crudo en narrativas inmersivas. Desde documentales y corporativos, hasta contenido ágil para redes diseñado para atrapar la atención.
                </p>

                <!-- Herramientas / Stack Tecnológico Destacado -->
                <div class="flex flex-wrap items-center gap-3 mb-12">
                    <span class="bg-black/50 backdrop-blur-sm border border-white/20 text-white text-xs font-bold px-4 py-2 rounded-full uppercase tracking-widest flex items-center gap-2">
                        <span class="text-[#9999ff] font-sans font-black">Pr</span> Premiere Pro
                    </span>
                    <span class="bg-black/50 backdrop-blur-sm border border-white/20 text-white text-xs font-bold px-4 py-2 rounded-full uppercase tracking-widest flex items-center gap-2">
                        <span class="text-[#9999ff] font-sans font-black">Ae</span> After Effects
                    </span>
                    <span class="bg-black/50 backdrop-blur-sm border border-white/20 text-white text-xs font-bold px-4 py-2 rounded-full uppercase tracking-widest flex items-center gap-2">
                        <i data-lucide="scissors" class="w-4 h-4 text-white"></i> CapCut Pro
                    </span>
                    <span class="bg-black/50 backdrop-blur-sm border border-white/20 text-white text-xs font-bold px-4 py-2 rounded-full uppercase tracking-widest flex items-center gap-2 hidden sm:flex">
                        <i data-lucide="pen-tool" class="w-4 h-4 text-[#F24E1E]"></i> Diseño UX/UI
                    </span>
                </div>
                
                <div class="flex flex-col sm:flex-row gap-6 items-start">
                    <a href="#proyectos" class="group flex items-center gap-4 bg-white text-kintsugi-dark px-8 py-5 rounded-full font-bold text-lg hover:bg-kintsugi-gold transition-all duration-300 shadow-[0_0_20px_rgba(255,255,255,0.3)]">
                        Ver Proyectos 
                        <i data-lucide="play-circle" class="w-6 h-6 group-hover:scale-110 transition-transform"></i>
                    </a>
                </div>
            </div>
        </div>
        
        <!-- Scroll indicator -->
        <div class="absolute bottom-10 left-6 flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-gray-400 -rotate-90 origin-left z-10">
            <span>Deslizar</span>
            <div class="w-16 h-[1px] bg-gray-600 relative overflow-hidden">
                <div class="absolute top-0 left-0 h-full w-1/3 bg-kintsugi-gold animate-[pulse_2s_infinite]"></div>
            </div>
        </div>
    </section>

    <!-- Sección Proyectos -->
