---
import PlantillaBase from "../layouts/PlantillaBase.astro";
import MiFoto from "../assets/img/MiFoto.png";
import CopyMail from "../components/links/copyMail.jsx";

const links = [
  {
    href: "https://www.linkedin.com/in/javier-cuevas-kintsugi/",
    label: "LinkedIn Profesional",
    objeto: "PerfilLinkedIn",
  },
  { href: "https://instagram.com/creativoskintsugi", label: "Instagram (Portafolio de Reels)", objeto: "PerfilInstagram" },
  { href: "https://wa.me/573000000000", label: "WhatsApp Directo (Agendar Llamada)", objeto: "PerfilWhatsApp" },
  { href: "mailto:contacto@creativoskintsugi.com", label: "Enviar Correo Electrónico", objeto: "CorreoElectronico" },
];
---

<PlantillaBase titulo="Contacto - Javier Cuevas | Creativos Kintsugi" descripcion="Ponte en contacto con Javier Cuevas, estratega de viralidad y editor de video cinematográfico en Creativos Kintsugi.">
  <section
    class="bg-gray-900 flex min-h-screen flex-col items-center justify-center px-6"
    data-sujeto="SeccionContacto"
    data-predicado="contieneOpcionesContacto"
    data-objeto="EnlacesRedes"
  >
    <div class="mb-2 mt-11">
      <div class="mb-2 mt-11">
        <div class="relative flex items-center justify-center">
          <!-- Foto con borde -->
          <img
            src={MiFoto.src}
            alt="Foto de Javier Cuevas"
            class="border-primary h-32 w-32 rounded-full shadow-lg"
            data-sujeto="FotoPerfil"
            data-predicado="representaA"
            data-objeto="JavierCuevas"
          />

          <!-- Texto circular alrededor de la foto -->
          <svg
            viewBox="0 0 200 200"
            class="animate-spin-slow absolute h-48 w-48"
          >
            <path
              id="circlePathText"
              d="M100,100 m-77,0 a77,77 0 1,1 154,0 a77,77 0 1,1 -154,0"
              fill="none"></path>
            <text fill="#ef4444" font-size="16" font-weight="bold">
              <textPath href="#circlePathText" startOffset="0%">
                ✦ KINTSUGI ✦ VIDEO VIRAL ✦ EDICIÓN CINEMÁTICA ✦
              </textPath>
            </text>
          </svg>
        </div>
      </div>
    </div>

    <CopyMail client:visible />

    <!-- Lista de Links -->
    <div class="w-full max-w-xl space-y-4" data-sujeto="ContenedorEnlaces" data-predicado="contieneRedes" data-objeto="LinksSociales">
      {
        links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="block font-bold w-full rounded-lg bg-primary hover:bg-secondary drop-shadow-[2px_2px_0_#ef4444] px-6 py-3 text-center text-white transition "
            data-sujeto="EnlaceContacto"
            data-predicado="conectaCon"
            data-objeto={link.objeto}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </section>
</PlantillaBase>

<style>
  .animate-spin-slow {
    animation: spin 25s linear infinite;
  }

  @keyframes spin {
    100% {
      transform: rotate(360deg);
    }
  }
</style>
