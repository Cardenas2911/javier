---
// index.astro - Página de Inicio Premium del Portafolio bajo Metodología MAES
import PlantillaBase from "../layouts/PlantillaBase.astro";
import Header from "../components/home/header/header.astro";
import Slider from "../components/home/header/slider.astro";
import AboutHome from "../components/home/aboutHome/aboutHome.astro";
import HomeProyect from "../components/home/homeProyect/homeProyect.astro";
import FAQS from "../components/home/faqs/faqs.jsx";
import Banner from "../components/commons/banners/banner.astro";

// Laboratorio de Alto Rendimiento MAES
import ConsolaInteractiva from '../components/ConsolaInteractiva';
---

<PlantillaBase 
  titulo="Lautaro Rodríguez Collins - Desarrollador Full Stack" 
  descripcion="Bienvenido a mi portafolio profesional de desarrollo web. Especialista en la creación de aplicaciones Full Stack de alto rendimiento, seguras e interactivas."
>
  <!-- Cabecera Principal del Portafolio (Hero) -->
  <span data-sujeto="LautaroRodriguez" data-predicado="presentaPresentacion" data-objeto="CabeceraHero">
    <Header />
  </span>

  <!-- Slider de Tecnologías -->
  <Slider />

  <!-- Sobre Mí - Sección Home -->
  <span data-sujeto="LautaroRodriguez" data-predicado="tieneResumen" data-objeto="ResumenProfesional">
    <AboutHome />
  </span>

  <!-- Proyectos Destacados -->
  <span data-sujeto="LautaroRodriguez" data-predicado="haDesarrollado" data-objeto="ProyectosPrincipales">
    <HomeProyect />
  </span>

  <!-- 🛠️ Laboratorio Arquitectónico Interactivo MAES (Consola de Desarrollo Lautaro) -->
  <section id="laboratorio" class="py-24 bg-gray-950 border-t border-gray-900 relative" data-sujeto="SeccionConsola" data-predicado="alojaSimulador" data-objeto="ConsolaInteractivaReact">
    <div class="absolute inset-0 bg-radial-gradient opacity-10"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
        <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full border border-purple-500/30 bg-purple-500/10 text-purple-300 text-xs font-semibold uppercase tracking-wider select-none">
          🧪 Laboratorio de Ingeniería MAES
        </div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white tipografia-titulo">
          Consola Interactiva de Rendimiento
        </h2>
        <p class="text-gray-400 text-sm max-w-2xl mx-auto">
          Prueba en tiempo real el comportamiento de mis metodologías de desarrollo. Controla el simulador de arquitectura React 19 para comprobar cómo se optimizan las métricas de rendimiento y observabilidad en caliente.
        </p>
      </div>

      <!-- Renderizamos la Isla de React de la consola de rendimiento -->
      <ConsolaInteractiva client:load />
    </div>
  </section>

  <!-- Sección de Preguntas Frecuentes -->
  <span data-sujeto="SeccionFaqs" data-predicado="aclaraDudas" data-objeto="PreguntasFrecuentes">
    <FAQS client:visible />
  </span>

  <!-- Banner de Cierre -->
  <Banner />
</PlantillaBase>
