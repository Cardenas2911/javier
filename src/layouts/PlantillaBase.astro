---
// PlantillaBase.astro - Plantilla principal segura del portafolio bajo Metodología MAES
import '../styles/global.css';
import { inicializarSentry } from '../lib/telemetria.ts';
import Navbar from '../components/commons/navbar/navbar.astro';
import Footer from '../components/commons/footer/footer.astro';

interface Props {
  titulo: string;
  descripcion?: string;
}

const { titulo, descripcion = "Portafolio profesional optimizado con Metodología MAES, Astro, React, Tailwind CSS y telemetría de Sentry" } = Astro.props;

// Inicialización de Sentry en el Servidor (Priorizando Seguridad y Observabilidad)
inicializarSentry();
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Metaetiquetas SEO -->
    <title>{titulo} | Portafolio Profesional</title>
    <meta name="description" content={descripcion} />
    <meta name="robots" content="index, follow" />
    
    <!-- Tipografías Premium desde Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Estilos en línea para variables tipográficas globales y adaptabilidad -->
    <style>
      :root {
        --fuente-base: 'Plus Jakarta Sans', sans-serif;
        --fuente-titulo: 'Space Grotesk', sans-serif;
      }
      body {
        font-family: var(--fuente-base);
        background-color: #030712; /* Fondo ultra oscuro premium */
        color: #f3f4f6;
      }
      .tipografia-titulo {
        font-family: var(--fuente-titulo);
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden selection:bg-red-650/30 selection:text-red-200" data-sujeto="PortafolioSeguro" data-predicado="instanciaDe" data-objeto="AplicacionMAES">
    <!-- Fondo decorativo con gradientes orbitales fluidos del portafolio original y animaciones MAES -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute -top-[40%] -left-[20%] w-[80vw] h-[80vw] rounded-full bg-red-900/15 blur-[120px] animate-gradientMove"></div>
      <div class="absolute -bottom-[20%] -right-[10%] w-[60vw] h-[60vw] rounded-full bg-red-950/15 blur-[100px] animate-gradientMove2"></div>
    </div>

    <!-- Navegación del Portafolio con Marcado Semántico AEO -->
    <header data-sujeto="CabeceraNavegacion" data-predicado="contieneMenu" data-objeto="NavegacionPortafolio">
      <Navbar />
    </header>

    <!-- Contenido Principal con Aislamiento e Inyección de Tripletas -->
    <main class="flex-grow pt-24" data-sujeto="ContenidoPrincipal" data-predicado="renderizaVistas" data-objeto="ComponentesPortafolio">
      <slot />
    </main>

    <!-- Pie de Página con Inyección de Seguridad y AEO -->
    <footer data-sujeto="PiePagina" data-predicado="contieneInformacion" data-objeto="DerechosPortafolio">
      <Footer />
    </footer>

    <!-- Script de Cliente para Observabilidad de Sentry en Caliente -->
    <script>
      import { inicializarSentry } from '../lib/telemetria.ts';
      inicializarSentry();
    </script>
  </body>
</html>
