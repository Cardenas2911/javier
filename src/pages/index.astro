---
// index.astro - Página principal premium de la Metodología MAES
import PlantillaBase from '../layouts/PlantillaBase.astro';
import IconoAnimado from '../components/IconoAnimado.astro';
import ConsolaInteractiva from '../components/ConsolaInteractiva';

// Enlaces de iconos animados de Lordicon CDN oficiales
const iconoModularidad = "https://cdn.lordicon.com/lupuorrc.json"; // Engranajes interactivos
const iconoRendimiento = "https://cdn.lordicon.com/qhgxgnkq.json"; // Rayo de energía
const iconoEstructura = "https://cdn.lordicon.com/fpipqwfg.json";   // Documentos / Estructura jerárquica
const iconoSeguridad = "https://cdn.lordicon.com/shlqjkun.json";    // Escudo protector activo
const iconoFuego = "https://cdn.lordicon.com/mrd91e4s.json";        // Fuego animado para el éxito
---

<PlantillaBase 
  titulo="Metodología MAES - Alto Rendimiento Web" 
  descripcion="Inicializa proyectos web de clase mundial y velocidad extrema con la metodología MAES utilizando Astro 5, React 19, Tailwind CSS 4 y animación fluida."
>
  <!-- Sección de Introducción (Hero) -->
  <section id="inicio" class="relative pt-24 pb-20 md:pt-32 md:pb-28 overflow-hidden" data-sujeto="SeccionHero" data-predicado="presentaMetodologia" data-objeto="MetodologiaMAES">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      {/* Contenido de la Introducción */}
      <div class="lg:col-span-7 space-y-8 text-center lg:text-left">
        <div class="inline-flex items-center gap-2.5 px-4.5 py-2 rounded-full border border-indigo-500/30 bg-indigo-500/10 text-indigo-300 text-xs font-semibold uppercase tracking-wider select-none animate-pulse">
          <IconoAnimado ruta={iconoFuego} tamano={22} colorPrimario="#818cf8" colorSecundario="#c084fc" disparador="loop" />
          Inicialización MAES Completa
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-white leading-tight tipografia-titulo">
          Desarrollo Web de 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-purple-400 to-cyan-400">
            Clase Mundial
          </span> 
          y Alto Rendimiento
        </h1>

        <p class="text-gray-400 text-base sm:text-lg max-w-2xl mx-auto lg:mx-0 leading-relaxed font-light">
          Bienvenidos a la vanguardia de la ingeniería de software. A través de la <strong class="text-white font-medium">Metodología MAES</strong>, construimos arquitecturas ultrarrápidas, modulares y seguras listas para escalar exponencialmente.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
          <a href="#demostracion" class="w-full sm:w-auto px-8 py-4 rounded-2xl bg-gradient-to-r from-indigo-600 to-cyan-500 hover:from-indigo-500 hover:to-cyan-400 text-white font-semibold text-sm transition-all duration-300 shadow-xl shadow-indigo-600/20 hover:shadow-indigo-500/35 hover:-translate-y-0.5 text-center flex items-center justify-center gap-2 group">
            Probar Simulador
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          
          <a href="#pilares" class="w-full sm:w-auto px-8 py-4 rounded-2xl border border-gray-800 bg-gray-900/40 hover:bg-gray-900/80 text-gray-300 hover:text-white font-semibold text-sm transition-all duration-300 hover:border-gray-700 text-center">
            Conocer Pilares
          </a>
        </div>
      </div>

      {/* Tarjeta Ilustrativa de Rendimiento (Lado Derecho) */}
      <div class="lg:col-span-5 relative flex justify-center">
        <div class="absolute -inset-1 rounded-[32px] bg-gradient-to-tr from-indigo-500 to-cyan-400 opacity-20 blur-[15px] group-hover:opacity-40 transition duration-1000"></div>
        <div class="relative w-full max-w-[380px] sm:max-w-[400px] rounded-3xl border border-gray-800 bg-gray-950/90 p-8 shadow-2xl space-y-6">
          <div class="flex justify-between items-center">
            <span class="text-xs font-bold text-gray-500 uppercase tracking-widest">Estado del Servidor</span>
            <span class="flex items-center gap-1.5 text-xs font-semibold text-emerald-400 bg-emerald-400/10 px-2.5 py-1 rounded-full">
              <span class="w-2 h-2 rounded-full bg-emerald-400 animate-ping"></span>
              En Línea
            </span>
          </div>

          <div class="space-y-4">
            <div class="flex justify-between items-end border-b border-gray-900 pb-3">
              <span class="text-sm font-medium text-gray-400">Motor Astro v5</span>
              <span class="text-sm font-bold text-indigo-400">Activo (Vite v6)</span>
            </div>
            <div class="flex justify-between items-end border-b border-gray-900 pb-3">
              <span class="text-sm font-medium text-gray-400">Estilos CSS</span>
              <span class="text-sm font-bold text-cyan-400">Tailwind CSS v4</span>
            </div>
            <div class="flex justify-between items-end border-b border-gray-900 pb-3">
              <span class="text-sm font-medium text-gray-400">Librería de Iconos</span>
              <span class="text-sm font-bold text-purple-400">Lordicon Element</span>
            </div>
            <div class="flex justify-between items-end">
              <span class="text-sm font-medium text-gray-400">Tiempo de Carga</span>
              <span class="text-sm font-bold text-emerald-400">0.08s (Instantáneo)</span>
            </div>
          </div>

          <div class="p-4 rounded-2xl bg-indigo-950/20 border border-indigo-900/30 flex items-center gap-3">
            <div class="p-2 rounded-xl bg-indigo-500/10 text-indigo-300">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold text-white uppercase">Isla React Activada</p>
              <p class="text-[11px] text-gray-400 mt-0.5">Componentes con carga diferida parcial</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección de Pilares Metodología MAES -->
  <section id="pilares" class="py-20 bg-gray-900/20 border-y border-gray-900" data-sujeto="SeccionPilares" data-predicado="describePilaresDe" data-objeto="MetodologiaMAES">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-3">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white tipografia-titulo">
          Los Pilares de la Metodología <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-cyan-300 font-extrabold">MAES</span>
        </h2>
        <p class="text-gray-400 text-base">
          Una estrategia de ingeniería de software diseñada específicamente para garantizar la robustez, el bajo consumo de recursos y la escalabilidad del sistema.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {/* M - Modularidad */}
        <div class="p-8 rounded-3xl border border-gray-800 bg-gray-950/50 hover:bg-gray-950 hover:border-indigo-500/40 hover:shadow-xl hover:shadow-indigo-900/10 transition-all duration-300 group">
          <div class="mb-6 flex justify-start">
            <div class="p-3 rounded-2xl bg-indigo-500/10 text-indigo-400 group-hover:scale-110 transition-transform duration-300">
              <IconoAnimado ruta={iconoModularidad} tamano={48} colorPrimario="#6366f1" colorSecundario="#818cf8" disparador="hover" />
            </div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 tracking-tight tipografia-titulo flex items-center gap-2">
            <span class="text-indigo-400 font-mono">M</span>odularidad
          </h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Estructuración en componentes independientes y atómicos. Lógica desacoplada de la UI que facilita el mantenimiento preventivo y los flujos ágiles.
          </p>
        </div>

        {/* A - Alto Rendimiento */}
        <div class="p-8 rounded-3xl border border-gray-800 bg-gray-950/50 hover:bg-gray-950 hover:border-cyan-400/40 hover:shadow-xl hover:shadow-cyan-900/10 transition-all duration-300 group">
          <div class="mb-6 flex justify-start">
            <div class="p-3 rounded-2xl bg-cyan-500/10 text-cyan-400 group-hover:scale-110 transition-transform duration-300">
              <IconoAnimado ruta={iconoRendimiento} tamano={48} colorPrimario="#06b6d4" colorSecundario="#22d3ee" disparador="hover" />
            </div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 tracking-tight tipografia-titulo flex items-center gap-2">
            <span class="text-cyan-400 font-mono">A</span>lto Rendimiento
          </h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Astro envía cero JavaScript al cliente por defecto. Las páginas se renderizan de inmediato y los componentes se activan únicamente bajo demanda física.
          </p>
        </div>

        {/* E - Estructura Limpia */}
        <div class="p-8 rounded-3xl border border-gray-800 bg-gray-950/50 hover:bg-gray-950 hover:border-purple-500/40 hover:shadow-xl hover:shadow-purple-900/10 transition-all duration-300 group">
          <div class="mb-6 flex justify-start">
            <div class="p-3 rounded-2xl bg-purple-500/10 text-purple-400 group-hover:scale-110 transition-transform duration-300">
              <IconoAnimado ruta={iconoEstructura} tamano={48} colorPrimario="#a855f7" colorSecundario="#c084fc" disparador="hover" />
            </div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 tracking-tight tipografia-titulo flex items-center gap-2">
            <span class="text-purple-400 font-mono">E</span>structura Limpia
          </h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Organización intuitiva y estandarizada. Rutas, layouts y componentes desacoplados con flujos de datos limpios y completamente legibles.
          </p>
        </div>

        {/* S - Seguridad */}
        <div class="p-8 rounded-3xl border border-gray-800 bg-gray-950/50 hover:bg-gray-950 hover:border-emerald-500/40 hover:shadow-xl hover:shadow-emerald-900/10 transition-all duration-300 group">
          <div class="mb-6 flex justify-start">
            <div class="p-3 rounded-2xl bg-emerald-500/10 text-emerald-400 group-hover:scale-110 transition-transform duration-300">
              <IconoAnimado ruta={iconoSeguridad} tamano={48} colorPrimario="#10b981" colorSecundario="#34d399" disparador="hover" />
            </div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 tracking-tight tipografia-titulo flex items-center gap-2">
            <span class="text-emerald-400 font-mono">S</span>eguridad Estricta
          </h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Tipado estricto en Typescript, desinfección preventiva de entradas en formularios y manejo inteligente del estado contra vulnerabilidades.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección de Tecnologías Utilizadas -->
  <section id="tecnologias" class="py-20 relative overflow-hidden" data-sujeto="SeccionTecnologias" data-predicado="utilizaHerramientas" data-objeto="StackTecnologicoModerno">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5 space-y-6">
          <h2 class="text-3xl font-bold tracking-tight text-white tipografia-titulo">
            Tecnologías de Última Generación
          </h2>
          <p class="text-gray-400 text-sm leading-relaxed font-light">
            Nuestra arquitectura no hace concesiones. Integramos herramientas líderes de la industria que garantizan el éxito en producción, combinadas de forma coherente bajo la Metodología MAES.
          </p>
          
          <ul class="space-y-4 text-sm font-semibold text-gray-300">
            <li class="flex items-center gap-3">
              <span class="p-1 rounded-full bg-indigo-500/10 text-indigo-400">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
              </span>
              Astro v5 como Núcleo de Generación Estática
            </li>
            <li class="flex items-center gap-3">
              <span class="p-1 rounded-full bg-cyan-500/10 text-cyan-400">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
              </span>
              React v19 para Islas de Interactividad Dinámica
            </li>
            <li class="flex items-center gap-3">
              <span class="p-1 rounded-full bg-purple-500/10 text-purple-400">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
              </span>
              Tailwind CSS v4 con Integración Nativa de Vite v6
            </li>
            <li class="flex items-center gap-3">
              <span class="p-1 rounded-full bg-emerald-500/10 text-emerald-400">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
              </span>
              Lordicon para Micro-interacciones Vectoriales
            </li>
          </ul>
        </div>

        <div class="lg:col-span-7 grid grid-cols-2 gap-4">
          <div class="p-6 rounded-2xl bg-gray-950/80 border border-gray-900 flex flex-col items-center justify-center text-center space-y-2 hover:border-gray-800 transition-colors">
            <span class="text-3xl font-extrabold text-white">100/100</span>
            <span class="text-xs font-bold text-indigo-400 uppercase">Métrica Lighthouse</span>
            <p class="text-[11px] text-gray-500">Velocidad garantizada en móvil y escritorio.</p>
          </div>
          
          <div class="p-6 rounded-2xl bg-gray-950/80 border border-gray-900 flex flex-col items-center justify-center text-center space-y-2 hover:border-gray-800 transition-colors">
            <span class="text-3xl font-extrabold text-white">Cero</span>
            <span class="text-xs font-bold text-cyan-400 uppercase">Bloqueo de Hilos</span>
            <p class="text-[11px] text-gray-500">Ejecución fluida y descompresión asíncrona.</p>
          </div>

          <div class="p-6 rounded-2xl bg-gray-950/80 border border-gray-900 flex flex-col items-center justify-center text-center space-y-2 hover:border-gray-800 transition-colors col-span-2">
            <span class="text-lg font-bold text-white tracking-tight">Vite v6 Integrado</span>
            <p class="text-xs text-gray-400">Compilación y empaquetado optimizado en tiempo récord con la tecnología más moderna.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección de Simulación y Demostración (Consola Interactiva React) -->
  <section id="demostracion" class="py-24 bg-gray-950 border-t border-gray-900 relative" data-sujeto="SeccionDemostracion" data-predicado="alojaSimulador" data-objeto="ConsolaInteractivaReact">
    <div class="absolute inset-0 bg-radial-gradient opacity-10"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white tipografia-titulo">
          Simulador Arquitectónico MAES
        </h2>
        <p class="text-gray-400 text-sm max-w-2xl mx-auto">
          Prueba el comportamiento de la arquitectura en tiempo real. Esta es una isla interactiva de React que renderiza dinámicamente según la carga y madurez técnica de los pilares.
        </p>
      </div>

      <!-- Renderizamos la Isla de React (Consola Interactiva) con carga hidratada en el cliente -->
      <ConsolaInteractiva client:load />
    </div>
  </section>
</PlantillaBase>
