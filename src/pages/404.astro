---
import PlantillaBase from "../layouts/PlantillaBase.astro";
---

<PlantillaBase titulo="Página No Encontrada (Error 404)" descripcion="La página que estás buscando no existe o ha sido movida temporalmente. Puedes regresar al inicio para continuar explorando el portafolio.">
  <section
    class="bg-gray-900 min-h-screen flex flex-col items-center justify-center px-6 text-center"
    data-sujeto="Seccion404"
    data-predicado="indicaError"
    data-objeto="PaginaNoEncontrada"
  >
    <h1
      class="text-7xl md:text-8xl font-extrabold text-[#69c7c7] drop-shadow-[3px_3px_0_#7836cf] mb-6"
    >
      404
    </h1>

    <h2 class="text-2xl md:text-3xl text-white font-semibold mb-6">
      Página no encontrada :/
    </h2>

    <p class="text-white/80 max-w-md mx-auto mb-10 font-bold">
      El enlace al que intentaste acceder no existe o fue movido. Pero
      tranquilo, podés volver al inicio y seguir navegando.
    </p>

    <a
      href="/"
      class="rounded-full bg-[#69c7c7] px-8 py-3 text-lg font-bold text-[#1d1250] drop-shadow-[3px_3px_0_#7836cf] transition-all duration-150 active:translate-y-0.5 active:drop-shadow-none"
    >
      Volver al inicio
    </a>
  </section>
</PlantillaBase>
