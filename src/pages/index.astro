                            <span class="text-[#9999ff] font-bold text-xl font-sans">Pr</span>
                        </div>
                        <span class="text-[10px] font-bold tracking-widest text-gray-400 uppercase">Premiere</span>
                    </div>
                    
                    <div class="flex flex-col items-center opacity-60 hover:opacity-100 transition-all hover:scale-110 cursor-pointer">
                        <div class="w-14 h-14 rounded-xl bg-[#00005c] flex items-center justify-center mb-3 border border-[#9999ff] shadow-[0_0_15px_rgba(153,153,255,0.2)]">
                            <span class="text-[#9999ff] font-bold text-xl font-sans">Ae</span>
                        </div>
                        <span class="text-[10px] font-bold tracking-widest text-gray-400 uppercase">After Effects</span>
                    </div>

                    <div class="flex flex-col items-center opacity-60 hover:opacity-100 transition-all hover:scale-110 cursor-pointer">
                        <div class="w-14 h-14 rounded-xl bg-black flex items-center justify-center mb-3 border border-[#F24E1E] shadow-[0_0_15px_rgba(242,78,30,0.2)]">
